package com.example.demo2;

import org.springframework.web.bind.annotation.*;
import jakarta.validation.Valid;

import java.util.ArrayList;
import java.util.List;

@RestController
@RequestMapping("/courses")
public class UniversityController {

    private List<CourseOffered> courses = new ArrayList<>();

    // CREATE
    @PostMapping
    public CourseOffered addCourse(@Valid @RequestBody CourseOffered course) {
        course.setId((long) (courses.size() + 1));
        courses.add(course);
        return course;
    }

    // READ (ALL)
    @GetMapping
    public List<CourseOffered> getAllCourses() {
        return courses;
    }

    // READ (BY ID)
    @GetMapping("/{id}")
    public CourseOffered getCourseById(@PathVariable Long id) {
        return courses.stream()
                .filter(c -> c.getId().equals(id))
                .findFirst()
                .orElse(null);
    }

    // UPDATE
    @PutMapping("/{id}")
    public CourseOffered updateCourse(@PathVariable Long id,
                                      @Valid @RequestBody CourseOffered updatedCourse) {

        for (CourseOffered course : courses) {
            if (course.getId().equals(id)) {
                course.setName(updatedCourse.getName());
                course.setLevel(updatedCourse.getLevel());
                return course;
            }
        }
        return null;
    }

    // DELETE
    @DeleteMapping("/{id}")
    public String deleteCourse(@PathVariable Long id) {
        courses.removeIf(c -> c.getId().equals(id));
        return "Course deleted successfully";
    }
}
